# Copy to .env.local for local `next dev`. On Cloudflare these are set in the
# Worker's Settings → Variables and Secrets (see DEPLOY.md), NOT committed here.

# Cloudflare Stream — the <CODE> in customer-<CODE>.cloudflarestream.com.
# Public, and INLINED AT BUILD TIME → set it as a Cloudflare *build* variable.
NEXT_PUBLIC_CF_STREAM_CUSTOMER_CODE=

# Resend (contact form) — runtime SECRETS on Cloudflare.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
# Optional From address. Use a Resend-verified sender; onboarding@resend.dev
# works until lvxhomes.com is verified in Resend.
CONTACT_FROM_EMAIL=
